import (
	"github.com/smart-core-os/sc-bos/pkg/minibus"
	"github.com/smart-core-os/sc-bos/pkg/util/cmp"
	"github.com/smart-core-os/sc-bos/pkg/util/masks"
	"github.com/smart-core-os/sc-bos/pkg/util/time"
)

var (
	_ = minibus.Bus{}
	_ = cmp.Message{}
	_ = masks.FieldMask{}
	_ = time.Clock{}
)
