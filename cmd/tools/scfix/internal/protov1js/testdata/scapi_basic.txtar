import {LightApiPromiseClient} from '@smart-core-os/sc-api-grpc-web/traits/light_grpc_web_pb';
import {Brightness} from '@smart-core-os/sc-api-grpc-web/traits/light_pb';
import {Tween} from '@smart-core-os/sc-api-grpc-web/types/tween_pb';
import {Period} from '@smart-core-os/sc-api-grpc-web/types/time/period_pb';

export function setBrightness(client, value) {
  return client.updateBrightness({brightness: new Brightness([value])});
}
