Test moving a trait package that already has 'pb' suffix (wastepb) from pkg/gentrait to pkg/proto.
expected_changes: 4

-- input/pkg/gentrait/wastepb/model.go --
package wastepb

import (
	"github.com/smart-core-os/sc-bos/pkg/proto/wastepb"
)

// NewModel creates a new Model server.
func NewModel() *wastepb.WasteLevel {
	return &wastepb.WasteLevel{}
}
-- input/pkg/gentrait/wastepb/consts/consts.go --
package consts

const MaxCapacity = 100
