{
  "name": "EG-02",
  "listenGrpc": ":23202",
  "listenHttps": ":8202",
  "cors": {
    "debugMode": true,
    "corsOrigins": ["*"]
  },
  "staticHosting": [
    {"path": "/__/vanti-ugs-cohort/", "filePath": "./example/config/vanti-ugs-cohort"}
  ],
  "systems": {
    "authn": {
      "user": {
        "fileAccounts": true,
        "keycloakAccounts": {
          "url": "http://localhost:8888",
          "realm": "Smart_Core",
          "clientId": "sc-opsui"
        }
      },
      "system": {"cohortAccounts": true},
      "tokenSigningKeyFile": "./example/config/vanti-ugs-cohort/authn_token_signing_key"
    },
    "resourceUse": {},
    "hub": {"storage": {"type": "proxy"}},
    "gateway": {},
    "tenants": {"storage": {"type": "proxy"}}
  }
}
